# Diese Datei dient nur als Dokumentation möglicher Build-Zeit-Variablen.
# Panel-URL und API-Keys werden bewusst NICHT über .env verwaltet, sondern
# zur Laufzeit über die Profilverwaltung in der App eingegeben und lokal
# über tauri-plugin-store im App-Datenverzeichnis des Nutzers gespeichert.
# Siehe README.md Abschnitt "Sicherheit" für Details und Grenzen.

# Optional: Feature-Flag, um das Application-API-Feld (Admin-Key) pro Profil
# standardmäßig sichtbar/ausgeblendet zu lassen. "true" | "false"
VITE_ENABLE_APPLICATION_API=true

# Optional: Standard-Auto-Refresh-Intervall für das Dashboard in Sekunden.
VITE_DEFAULT_REFRESH_INTERVAL=10
