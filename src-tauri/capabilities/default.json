{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Berechtigungen für das Hauptfenster der Pterodactyl-Desktop-App",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-set-title",
    "store:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "dialog:allow-confirm",
    "fs:allow-read-file",
    "fs:allow-write-file",
    "fs:scope-appdata-recursive",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "http://**" },
        { "url": "https://**" }
      ]
    },
    "shell:allow-open",
    "updater:default",
    "process:allow-restart"
  ]
}
